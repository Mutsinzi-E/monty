#include "monty.h"

/**
 * get_op_func - selects function
 */
void (*get_op_func(char *opcode))(stack_t **, unsigned int)
{
	int i = 0;

	instruction_t ops[] = {
		{"push", push},
		{"pall", pall},
		{"pop", pop},
		{"swap", swap},
		{"add", add},
		{NULL, NULL}
	};

	while (ops[i].opcode)
	{
		if (strcmp(opcode, ops[i].opcode) == 0)
			return (ops[i].f);
		i++;
	}

	return (NULL);
}
